# Copy this to .env and fill in your values
# NEVER commit .env to git

PORT=10000
CLIENT_URL=https://your-vendors-site.vercel.app

# Stripe — get these from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create one product per vendor in Stripe dashboard, copy the Price ID (starts with price_)
STRIPE_PRICE_ELECTRONICS=price_...
STRIPE_PRICE_SHOES=price_...
STRIPE_PRICE_JEWELRY=price_...
STRIPE_PRICE_HOODIES=price_...
STRIPE_PRICE_FRAGRANCE=price_...
STRIPE_PRICE_WATCHES=price_...
STRIPE_PRICE_CLOTHING=price_...
STRIPE_PRICE_BUNDLE=price_...
